print(set(clubstats['Squad']) - set(clubwage['Squad']))
print(set(clubwage['Squad']) - set(clubstats['Squad']))

# Removing hidden spaces from the club names in both datasets to ensure they match for merging

clubstats['Squad'] = clubstats['Squad'].str.replace('\xa0', '', regex = False).str.strip().str.lower()
clubwage['Squad'] = clubwage['Squad'].str.replace('\xa0', '', regex = False).str.strip().str.lower()

