# Standardising the wage data so that all wages are in GBP for both player wages and club wages 

import re 

def extract_pounds(value):
    if pd.isna(value):
        return None
    
    value = str(value)

    match = re.search(r'[£\xa3]\s*([\d,]+)', value)

    if match:
        return int(match.group(1).replace(",", ""))
    return None

# Applying the function to the 'Wage' column in playerwage and clubwage datasets
# Printing out the first few rows of the new columns we can see that the function has worked and all wages are now in GBP and in a numerical format which will allow us to perform calculations on them in the future

playerwage['Weekly Wages (GBP)'] = playerwage['Weekly Wages'].apply(extract_pounds)
playerwage['Annual Wages (GBP)'] = playerwage['Annual Wages'].apply(extract_pounds)

clubwage['Weekly Wages (GBP)'] = clubwage['Weekly Wages'].apply(extract_pounds)
clubwage['Annual Wages (GBP)'] = clubwage['Annual Wages'].apply(extract_pounds)

